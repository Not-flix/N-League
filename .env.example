# 管理パスワード（半荘入力・管理画面に必須）
ADMIN_PASSWORD=set-your-password

# セッション署名用シークレット（16文字以上のランダム文字列）
# 例: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-string

# 以下は Supabase を使う場合のみ。
# どちらか一方でも欠けていればローカル JSON ストア（data/league.json）を使用。
# SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
